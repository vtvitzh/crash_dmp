  "\"\n"
  "}\n"
  "embedded_components {\n"
  "  id: \"shadowFactory\"\n"
  "  type: \"factory\"\n"
  "  data: \"prototype: \\\"/main/shadow.go\\\"\\n"
  "\"\n"
  "}\n"
  ""
}
